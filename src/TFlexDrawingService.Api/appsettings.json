{
  "Paths": {
    "ProjectRoot": "../.."
  },
  "TemplateCatalog": {
    "ConfigPath": "templates/templates.json"
  },
  "Storage": {
    "RootPath": "storage",
    "DatabasePath": "storage/drawings.db"
  },
  "Queue": {
    "PollIntervalSeconds": 1
  },
  "TFlexAutomation": {
    "Mode": "ExternalProcess",
    "CommandPath": "",
    "Arguments": "\"{requestPath}\" \"{responsePath}\"",
    "TimeoutSeconds": 600,
    "WriteParameterFile": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
